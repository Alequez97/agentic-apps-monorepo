PORT=3002

# Absolute or backend-relative path for local file-backed storage.
# File-backed market-research data lives under:
#   <MR_DATA_DIR>/market-research/<sessionId>/
# File-backed queue data, logs, and temp progress live directly under:
#   <MR_DATA_DIR>/tasks
#   <MR_DATA_DIR>/logs
#   <MR_DATA_DIR>/temp
MR_DATA_DIR=.market-research/

# Storage providers
TASK_QUEUE_PROVIDER=file
APP_PERSISTENCE_PROVIDER=file

# Queue MongoDB settings
# Used when TASK_QUEUE_PROVIDER=mongo
TASK_QUEUE_MONGODB_URI=
TASK_QUEUE_MONGODB_DB_NAME=agentic_queue

# App persistence MongoDB settings
# Used when APP_PERSISTENCE_PROVIDER=mongo
APP_MONGODB_URI=
APP_MONGODB_DB_NAME=market_research_app

# LLM provider API keys - set at least one
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Brave Search API key - enables web_search tool for market research agents
BRAVE_SEARCH_API_KEY=

# Auth - required for authenticated sessions
JWT_SECRET=changeme_use_a_long_random_string
GOOGLE_CLIENT_ID=
