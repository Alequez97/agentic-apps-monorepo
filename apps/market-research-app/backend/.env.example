PORT=3002

# Absolute path to the directory where market research data is stored.
# Sessions are written to <MR_DATA_DIR>/market-research/<sessionId>/
# Queue files and logs are written to <MR_DATA_DIR>/.market-research/
MR_DATA_DIR=.market-research/

# LLM provider API keys — set at least one
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Brave Search API key — enables web_search tool for market research agents
BRAVE_SEARCH_API_KEY=

# Auth — required for authenticated sessions
JWT_SECRET=changeme_use_a_long_random_string
GOOGLE_CLIENT_ID=
